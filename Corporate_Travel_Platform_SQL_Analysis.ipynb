  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "s0_clean",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/html": [
       "<div>\n",
       "<style scoped>\n",
       "    .dataframe tbody tr th:only-of-type {\n",
       "        vertical-align: middle;\n",
       "    }\n",
       "\n",
       "    .dataframe tbody tr th {\n",
       "        vertical-align: top;\n",
       "    }\n",
       "\n",
       "    .dataframe thead th {\n",
       "        text-align: right;\n",
       "    }\n",
       "</style>\n",
       "<table border=\"1\" class=\"dataframe\">\n",
       "  <thead>\n",
       "    <tr style=\"text-align: right;\">\n",
       "      <th></th>\n",
       "      <th>raw_records</th>\n",
       "      <th>clean_records</th>\n",
       "      <th>removed</th>\n",
       "    </tr>\n",
       "  </thead>\n",
       "  <tbody>\n",
       "    <tr>\n",
       "      <th>0</th>\n",
       "      <td>300000</td>\n",
       "      <td>296273</td>\n",
       "      <td>3727</td>\n",
       "    </tr>\n",
       "  </tbody>\n",
       "</table>\n",
       "</div>"
      ],
      "text/plain": [
       "   raw_records  clean_records  removed\n",
       "0       300000         296273     3727"
      ]
     },
     "execution_count": 7,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Create bookings_clean — excludes:\n",
    "#   1. Revenue outlier: BOOKING_ID 1973157021 (~$100M Air refund)\n",
    "#   2. Invalid travel window: TRAVEL_END < TRAVEL_START\n",
    "#   3. Impossible booking:    TRAVEL_START < BOOKING_DATE\n",
    "#   4. Duplicate BOOKING_IDs: keep first occurrence\n",
    "con.execute(\"\"\"\n",
    "    CREATE OR REPLACE VIEW bookings_clean AS\n",
    "    SELECT * FROM (\n",
    "        SELECT *,\n",
    "               ROW_NUMBER() OVER (PARTITION BY BOOKING_ID ORDER BY BOOKING_DATE) AS rn\n",
    "        FROM bookings\n",
    "        WHERE BOOKING_ID != 1973157021\n",
    "          AND NOT (TRAVEL_END < TRAVEL_START AND TRAVEL_END IS NOT NULL AND TRAVEL_START IS NOT NULL)\n",
    "          AND NOT (TRAVEL_START < BOOKING_DATE AND TRAVEL_START IS NOT NULL)\n",
    "    )\n",
    "    WHERE rn = 1\n",
    "\"\"\")\n",
    "\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        (SELECT COUNT(*) FROM bookings)       AS raw_records,\n",
    "        (SELECT COUNT(*) FROM bookings_clean) AS clean_records,\n",
    "        (SELECT COUNT(*) FROM bookings)\n",
    "        - (SELECT COUNT(*) FROM bookings_clean) AS removed\n",
    "\"\"\").df()\n"
   ]
  },
