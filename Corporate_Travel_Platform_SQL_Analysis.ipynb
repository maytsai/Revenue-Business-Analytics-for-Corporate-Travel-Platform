   "source": [
    "# July vs rest of year: lead time of loss events\n",
    "con.execute(f\"\"\"\n",
    "    SELECT\n",
    "        CASE WHEN STRFTIME(BOOKING_DATE,'%m') = '07'\n",
    "             THEN 'July' ELSE 'Rest of Year' END AS period,\n",
    "        COUNT(*) AS loss_events,\n",
    "        MEDIAN(DATEDIFF('day', BOOKING_DATE, TRAVEL_START)) AS median_lead_days,\n",
    "        ROUND(AVG(DATEDIFF('day', BOOKING_DATE, TRAVEL_START)), 1) AS avg_lead_days\n",
    "    FROM bookings_clean\n",
    "    WHERE ({loss_filter}) AND TRAVEL_START IS NOT NULL\n",
    "    GROUP BY 1\n",
    "\"\"\").df()\n"
