   "source": [
    "# Hotel: monthly Cancel vs Refund with ratio\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        STRFTIME(BOOKING_DATE, '%Y-%m') AS month,\n",
    "        SUM(CASE WHEN BOOKING_TYPE_NAME = 'Cancel' THEN 1 ELSE 0 END) AS cancels,\n",
    "        SUM(CASE WHEN BOOKING_TYPE_NAME = 'Refund'  THEN 1 ELSE 0 END) AS refunds,\n",
    "        ROUND(SUM(CASE WHEN BOOKING_TYPE_NAME = 'Refund' THEN 1 ELSE 0 END) * 1.0\n",
    "              / NULLIF(SUM(CASE WHEN BOOKING_TYPE_NAME = 'Cancel' THEN 1 ELSE 0 END), 0),\n",
    "              1) AS refund_to_cancel_ratio\n",
    "    FROM bookings_clean\n",
    "    WHERE PRODUCT_NAME = 'Hotel' AND BOOKING_TYPE_NAME IN ('Cancel', 'Refund')\n",
    "    GROUP BY 1\n",
    "    ORDER BY 1\n",
    "\"\"\").df()\n"
   ]
  },
