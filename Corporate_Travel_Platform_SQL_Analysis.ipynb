   "source": [
    "# Booking amount distribution — percentiles to quantify outlier magnitude\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        printf('$%,.0f', PERCENTILE_CONT(0.50) WITHIN GROUP (ORDER BY ABS(BOOKING_AMOUNT))) AS p50,\n",
    "        printf('$%,.0f', PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY ABS(BOOKING_AMOUNT))) AS p95,\n",
    "        printf('$%,.0f', PERCENTILE_CONT(0.99) WITHIN GROUP (ORDER BY ABS(BOOKING_AMOUNT))) AS p99,\n",
    "        printf('$%,.0f', MAX(ABS(BOOKING_AMOUNT)))                                          AS max_val\n",
    "    FROM bookings\n",
    "    WHERE BOOKING_AMOUNT != 0\n",
    "\"\"\").df()"
   ]
