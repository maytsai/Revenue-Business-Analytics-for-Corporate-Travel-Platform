   "source": [
    "# July loss events: which travel month were they for?\n",
    "con.execute(f\"\"\"\n",
    "    SELECT\n",
    "        STRFTIME(TRAVEL_START, '%Y-%m') AS intended_travel_month,\n",
    "        COUNT(*) AS loss_events,\n",
    "        ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 1) AS pct\n",
    "    FROM bookings_clean\n",
    "    WHERE ({loss_filter})\n",
    "      AND STRFTIME(BOOKING_DATE, '%Y-%m') = '2018-07'\n",
    "      AND TRAVEL_START IS NOT NULL\n",
    "    GROUP BY 1\n",
    "    ORDER BY 1\n",
    "\"\"\").df()\n"
   ]
