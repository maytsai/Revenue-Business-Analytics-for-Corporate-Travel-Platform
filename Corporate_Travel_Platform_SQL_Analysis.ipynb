   "source": [
    "# Hotel: amount percentiles — Purchase vs Cancel vs Refund\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        BOOKING_TYPE_NAME,\n",
    "        ROUND(PERCENTILE_CONT(0.25) WITHIN GROUP (ORDER BY ABS(BOOKING_AMOUNT)), 0) AS p25,\n",
    "        ROUND(PERCENTILE_CONT(0.50) WITHIN GROUP (ORDER BY ABS(BOOKING_AMOUNT)), 0) AS median,\n",
    "        ROUND(PERCENTILE_CONT(0.75) WITHIN GROUP (ORDER BY ABS(BOOKING_AMOUNT)), 0) AS p75,\n",
    "        ROUND(AVG(ABS(BOOKING_AMOUNT)), 0)                                          AS avg\n",
    "    FROM bookings_clean\n",
    "    WHERE PRODUCT_NAME = 'Hotel'\n",
    "      AND BOOKING_TYPE_NAME IN ('Purchase', 'Cancel', 'Refund')\n",
    "    GROUP BY 1\n",
    "    ORDER BY CASE BOOKING_TYPE_NAME\n",
    "                 WHEN 'Purchase' THEN 1\n",
    "                 WHEN 'Cancel'   THEN 2\n",
    "                 ELSE 3 END\n",
    "\"\"\").df()\n"
   ]
  },
