    "# Hotel: Cancel vs Refund — volume, amount, lead time\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        BOOKING_TYPE_NAME,\n",
    "        COUNT(*)                                                          AS n,\n",
