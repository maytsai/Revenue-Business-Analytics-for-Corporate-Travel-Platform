   "source": [
    "# August product mix vs baseline (H2: product shift test)\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        STRFTIME(BOOKING_DATE, '%Y-%m')                                                    AS month,\n",
    "        PRODUCT_NAME,\n",
    "        COUNT(*)                                                                            AS n,\n",
    "        ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (PARTITION BY STRFTIME(BOOKING_DATE, '%Y-%m')), 1) AS pct\n",
    "    FROM bookings_clean\n",
    "    WHERE (PRODUCT_NAME IN ('Air', 'Hotel') AND BOOKING_TYPE_NAME = 'Purchase')\n",
    "       OR (PRODUCT_NAME = 'Car'             AND BOOKING_TYPE_NAME = 'Reserve')\n",
    "    GROUP BY 1, 2\n",
    "    ORDER BY 1, 2\n",
    "\"\"\").df()\n",
    "# Air share only moved 45.6% → 50.4% in Aug — not enough to explain 2x mean spike"
   ]
  },
