   "source": [
    "# NULL counts across key columns (raw data)\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        SUM(CASE WHEN BOOKING_ID     IS NULL THEN 1 ELSE 0 END) AS null_booking_id,\n",
    "        SUM(CASE WHEN TRAVELER_ID    IS NULL THEN 1 ELSE 0 END) AS null_traveler_id,\n",
    "        SUM(CASE WHEN BOOKING_DATE   IS NULL THEN 1 ELSE 0 END) AS null_booking_date,\n",
    "        SUM(CASE WHEN TRAVEL_START   IS NULL THEN 1 ELSE 0 END) AS null_travel_start,\n",
    "        SUM(CASE WHEN TRAVEL_END     IS NULL THEN 1 ELSE 0 END) AS null_travel_end,\n",
    "        SUM(CASE WHEN BOOKING_AMOUNT IS NULL THEN 1 ELSE 0 END) AS null_booking_amount,\n",
    "        SUM(CASE WHEN PRODUCT_NAME   IS NULL THEN 1 ELSE 0 END) AS null_product_name\n",
    "    FROM bookings\n",
    "\"\"\").df()\n"
   ]
