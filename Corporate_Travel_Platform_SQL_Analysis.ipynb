   "source": [
    "# Car: cancel amount distribution\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        CASE\n",
    "            WHEN ABS(BOOKING_AMOUNT) = 0    THEN '$0 (zero)'\n",
    "            WHEN ABS(BOOKING_AMOUNT) < 100  THEN 'Under $100'\n",
    "            WHEN ABS(BOOKING_AMOUNT) < 500  THEN '$100–$499'\n",
    "            WHEN ABS(BOOKING_AMOUNT) < 1000 THEN '$500–$999'\n",
    "            ELSE '$1,000+'\n",
    "        END AS amount_bucket,\n",
    "        COUNT(*) AS n,\n",
    "        ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 1) AS pct\n",
    "    FROM bookings_clean\n",
    "    WHERE PRODUCT_NAME = 'Car' AND BOOKING_TYPE_NAME = 'Cancel'\n",
    "    GROUP BY 1\n",
    "    ORDER BY MIN(ABS(BOOKING_AMOUNT))\n",
    "\"\"\").df()\n"
   ]
  },
