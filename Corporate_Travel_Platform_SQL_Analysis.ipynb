   "source": [
    "# July vs baseline: active travelers by frequency tier\n",
    "con.execute(\"\"\"\n",
    "    WITH traveler_tiers AS (\n",
    "        SELECT TRAVELER_ID,\n",
    "               CASE\n",
    "                   WHEN SUM(CASE WHEN (PRODUCT_NAME IN ('Air','Hotel') AND BOOKING_TYPE_NAME='Purchase')\n",
    "                                   OR (PRODUCT_NAME='Car' AND BOOKING_TYPE_NAME='Reserve')\n",
    "                                THEN 1 ELSE 0 END) <= 2 THEN 'One-time (1–2)'\n",
    "                   WHEN SUM(CASE WHEN (PRODUCT_NAME IN ('Air','Hotel') AND BOOKING_TYPE_NAME='Purchase')\n",
    "                                   OR (PRODUCT_NAME='Car' AND BOOKING_TYPE_NAME='Reserve')\n",
    "                                THEN 1 ELSE 0 END) <= 9 THEN 'Occasional (3–9)'\n",
    "                   ELSE 'Frequent (10+)'\n",
    "               END AS freq_tier\n",
    "        FROM bookings_clean\n",
    "        GROUP BY TRAVELER_ID\n",
    "    ),\n",
    "    monthly_active AS (\n",
    "        SELECT STRFTIME(b.BOOKING_DATE,'%m') AS month,\n",
    "               t.freq_tier,\n",
    "               COUNT(DISTINCT b.TRAVELER_ID) AS active_travelers\n",
    "        FROM bookings_clean b\n",
    "        JOIN traveler_tiers t ON b.TRAVELER_ID = t.TRAVELER_ID\n",
    "        WHERE (b.PRODUCT_NAME IN ('Air','Hotel') AND b.BOOKING_TYPE_NAME='Purchase')\n",
    "           OR (b.PRODUCT_NAME='Car' AND b.BOOKING_TYPE_NAME='Reserve')\n",
    "        GROUP BY 1, 2\n",
    "    )\n",
    "    SELECT\n",
    "        freq_tier,\n",
    "        ROUND(AVG(CASE WHEN month NOT IN ('07','08','12')\n",
    "                       THEN active_travelers END), 0) AS baseline_avg,\n",
    "        MAX(CASE WHEN month = '07' THEN active_travelers END) AS july,\n",
    "        ROUND(\n",
    "            (AVG(CASE WHEN month NOT IN ('07','08','12') THEN active_travelers END)\n",
    "             - MAX(CASE WHEN month = '07' THEN active_travelers END))\n",
    "            * 100.0\n",
    "            / AVG(CASE WHEN month NOT IN ('07','08','12') THEN active_travelers END),\n",
    "        1) AS drop_pct\n",
    "    FROM monthly_active\n",
    "    GROUP BY freq_tier\n",
    "    ORDER BY MIN(freq_tier)\n",
    "\"\"\").df()\n"
   ]
  },
