   "source": [
    "#High level dataset summary\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        COUNT(*)                                             AS total_records,\n",
    "        COUNT(DISTINCT BOOKING_ID)                           AS unique_bookings,\n",
    "        COUNT(DISTINCT TRAVELER_ID)                          AS unique_travelers,\n",
    "        MIN(BOOKING_DATE)                                    AS earliest_booking,\n",
    "        MAX(BOOKING_DATE)                                    AS latest_booking,\n",
    "        printf('$%.2f', SUM(BOOKING_AMOUNT))                 AS total_booking_amount,\n",
    "        printf('$%.2f', AVG(BOOKING_AMOUNT))                 AS avg_booking_amount\n",
    "    FROM bookings_clean\n",
    "\"\"\").df()\n"
   ]
