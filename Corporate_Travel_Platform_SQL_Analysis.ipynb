    "# Zero-amount bookings by product and type\n",
    "con.execute(\"\"\"\n",
    "    SELECT PRODUCT_NAME, BOOKING_TYPE_NAME, COUNT(*) AS n\n",
    "    FROM bookings\n",
    "    WHERE BOOKING_AMOUNT = 0\n",
    "    GROUP BY 1, 2\n",
    "    ORDER BY 3 DESC\n",
    "\"\"\").df()\n"
   ]
