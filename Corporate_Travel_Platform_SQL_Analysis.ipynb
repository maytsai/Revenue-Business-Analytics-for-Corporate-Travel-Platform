   "source": [
    "# Monthly loss rate — all products combined\n",
    "con.execute(f\"\"\"\n",
    "    SELECT\n",
    "        STRFTIME(BOOKING_DATE, '%Y-%m') AS month,\n",
    "        SUM(CASE WHEN (PRODUCT_NAME IN ('Air','Hotel') AND BOOKING_TYPE_NAME='Purchase')\n",
    "                   OR (PRODUCT_NAME='Car' AND BOOKING_TYPE_NAME='Reserve')\n",
    "                 THEN 1 ELSE 0 END) AS purchases,\n",
    "        SUM(CASE WHEN {loss_filter} THEN 1 ELSE 0 END) AS loss_events,\n",
    "        ROUND(\n",
    "            SUM(CASE WHEN {loss_filter} THEN 1 ELSE 0 END) * 100.0 /\n",
    "            NULLIF(SUM(CASE WHEN (PRODUCT_NAME IN ('Air','Hotel') AND BOOKING_TYPE_NAME='Purchase')\n",
    "                               OR (PRODUCT_NAME='Car' AND BOOKING_TYPE_NAME='Reserve')\n",
    "                               OR ({loss_filter}) THEN 1 ELSE 0 END), 0), 1) AS loss_rate_pct\n",
    "    FROM bookings_clean\n",
    "    GROUP BY 1\n",
    "    ORDER BY 1\n",
    "\"\"\").df()\n"
   ]
