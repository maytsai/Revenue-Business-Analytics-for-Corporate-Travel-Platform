   "source": [
    "# Average booking value by month — checks for price shift in July/Aug\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        STRFTIME(BOOKING_DATE, '%Y-%m') AS month,\n",
    "        COUNT(*) AS bookings,\n",
    "        ROUND(AVG(BOOKING_AMOUNT), 2) AS avg_booking_value,\n",
    "        printf('$%.0f', SUM(BOOKING_AMOUNT)) AS total_revenue\n",
    "    FROM bookings_clean\n",
    "    WHERE (PRODUCT_NAME IN ('Air','Hotel') AND BOOKING_TYPE_NAME = 'Purchase')\n",
    "       OR (PRODUCT_NAME = 'Car' AND BOOKING_TYPE_NAME = 'Reserve')\n",
    "    GROUP BY 1\n",
    "    ORDER BY 1\n",
    "\"\"\").df()\n"
   ]
  },
