   "source": [
    "loss_filter = \"\"\"\n",
    "    (PRODUCT_NAME = 'Air'   AND BOOKING_TYPE_NAME IN ('Refund', 'Partial Refund', 'Void'))\n",
    " OR (PRODUCT_NAME = 'Hotel' AND BOOKING_TYPE_NAME IN ('Cancel', 'Refund'))\n",
    " OR (PRODUCT_NAME = 'Car'   AND BOOKING_TYPE_NAME = 'Cancel')\n",
    "\"\"\"\n",
    "\n",
    "# Monthly purchase volume, loss events, and revenue lost\n",
    "con.execute(f\"\"\"\n",
    "    SELECT\n",
    "        STRFTIME(BOOKING_DATE, '%Y-%m') AS month,\n",
    "        SUM(CASE WHEN (PRODUCT_NAME IN ('Air','Hotel') AND BOOKING_TYPE_NAME='Purchase')\n",
    "                   OR (PRODUCT_NAME='Car' AND BOOKING_TYPE_NAME='Reserve')\n",
    "                 THEN 1 ELSE 0 END) AS purchases,\n",
    "        SUM(CASE WHEN {loss_filter} THEN 1 ELSE 0 END) AS loss_events,\n",
    "        printf('$%.0f', SUM(CASE WHEN {loss_filter}\n",
    "                                 THEN ABS(BOOKING_AMOUNT) ELSE 0 END)) AS revenue_lost\n",
    "    FROM bookings_clean\n",
    "    GROUP BY 1\n",
    "    ORDER BY 1\n",
    "\"\"\").df()\n"
   ]
