   "source": [
    "# August avg booking value by traveler tier (H1: composition effect test)\n",
    "con.execute(\"\"\"\n",
    "    WITH tier AS (\n",
    "        SELECT\n",
    "            TRAVELER_ID,\n",
    "            CASE\n",
    "                WHEN SUM(CASE WHEN (PRODUCT_NAME IN ('Air','Hotel') AND BOOKING_TYPE_NAME = 'Purchase')\n",
    "                                OR (PRODUCT_NAME = 'Car'            AND BOOKING_TYPE_NAME = 'Reserve')\n",
    "                              THEN 1 ELSE 0 END) <= 2 THEN 'One-time'\n",
    "                WHEN SUM(CASE WHEN (PRODUCT_NAME IN ('Air','Hotel') AND BOOKING_TYPE_NAME = 'Purchase')\n",
    "                                OR (PRODUCT_NAME = 'Car'            AND BOOKING_TYPE_NAME = 'Reserve')\n",
    "                              THEN 1 ELSE 0 END) <= 9 THEN 'Occasional'\n",
    "                ELSE 'Frequent'\n",
    "            END AS freq_tier\n",
    "        FROM bookings_clean\n",
    "        GROUP BY TRAVELER_ID\n",
    "    )\n",
    "    SELECT\n",
    "        STRFTIME(b.BOOKING_DATE, '%Y-%m') AS month,\n",
    "        t.freq_tier,\n",
    "        COUNT(*)                          AS bookings,\n",
    "        ROUND(AVG(b.BOOKING_AMOUNT), 0)   AS avg_value\n",
    "    FROM bookings_clean b\n",
    "    JOIN tier t ON b.TRAVELER_ID = t.TRAVELER_ID\n",
    "    WHERE (b.PRODUCT_NAME IN ('Air', 'Hotel') AND b.BOOKING_TYPE_NAME = 'Purchase')\n",
    "       OR (b.PRODUCT_NAME = 'Car'             AND b.BOOKING_TYPE_NAME = 'Reserve')\n",
    "    GROUP BY 1, 2\n",
    "    ORDER BY 1, 2\n",
    "\"\"\").df()\n",
    "# Frequent tier avg spiked to $3,961 in Aug but median confirms this is tail-driven, not structural"
   ]
  },
