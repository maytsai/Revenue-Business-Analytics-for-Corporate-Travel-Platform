   "source": [
    "# Top 10 bookings by absolute amount — outlier discovery\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        BOOKING_ID,\n",
    "        PRODUCT_NAME,\n",
    "        BOOKING_TYPE_NAME,\n",
    "        printf('$%,.0f', BOOKING_AMOUNT) AS amount\n",
    "    FROM bookings\n",
    "    ORDER BY ABS(BOOKING_AMOUNT) DESC\n",
    "    LIMIT 10\n",
    "\"\"\").df()"
   ]
