   "source": [
    "# Car: cancel lead time summary stats\n",
    "con.execute(\"\"\"\n",
    "    SELECT\n",
    "        COUNT(*) AS total_cancels,\n",
    "        SUM(CASE WHEN DATEDIFF('day', BOOKING_DATE, TRAVEL_START) = 0\n",
    "                 THEN 1 ELSE 0 END) AS same_day,\n",
    "        SUM(CASE WHEN DATEDIFF('day', BOOKING_DATE, TRAVEL_START)\n",
    "                 BETWEEN 1 AND 3 THEN 1 ELSE 0 END) AS d1_to_3,\n",
    "        MEDIAN(DATEDIFF('day', BOOKING_DATE, TRAVEL_START)) AS median_lead_days,\n",
    "        ROUND(AVG(DATEDIFF('day', BOOKING_DATE, TRAVEL_START)), 1) AS avg_lead_days,\n",
    "        ROUND(AVG(ABS(BOOKING_AMOUNT)), 2) AS avg_cancel_amount\n",
    "    FROM bookings_clean\n",
    "    WHERE PRODUCT_NAME = 'Car' AND BOOKING_TYPE_NAME = 'Cancel'\n",
    "      AND TRAVEL_START IS NOT NULL\n",
    "\"\"\").df()\n"
   ]
  },
