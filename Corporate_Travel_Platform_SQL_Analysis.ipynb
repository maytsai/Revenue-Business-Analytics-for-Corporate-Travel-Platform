   "source": [
    "# Monthly total bookings with MoM % change\n",
    "con.execute(\"\"\"\n",
    "    SELECT month, total_bookings,\n",
    "           LAG(total_bookings) OVER (ORDER BY month) AS prev_month,\n",
    "           ROUND((total_bookings - LAG(total_bookings) OVER (ORDER BY month))\n",
    "                 * 100.0 / LAG(total_bookings) OVER (ORDER BY month), 1) AS mom_pct\n",
    "    FROM (\n",
    "        SELECT STRFTIME(BOOKING_DATE,'%Y-%m') AS month, COUNT(*) AS total_bookings\n",
    "        FROM bookings_clean\n",
    "        WHERE (PRODUCT_NAME IN ('Air','Hotel') AND BOOKING_TYPE_NAME = 'Purchase')\n",
    "           OR (PRODUCT_NAME = 'Car' AND BOOKING_TYPE_NAME = 'Reserve')\n",
    "        GROUP BY 1\n",
    "    )\n",
    "    ORDER BY month\n",
    "\"\"\").df()\n"
   ]
  },
